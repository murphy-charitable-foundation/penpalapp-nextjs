# Local development should point at the Firebase dev project.
# Copy this file to .env.local before running `npm run dev`.

# Server-side Firebase Admin routes need a dev service account.
# Keep this in .env.local only. Never commit it.
# Use a single-line JSON string:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"penpalmagicapp-dev",...}
